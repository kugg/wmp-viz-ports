+/**
+ * @brief Writes a 24-bit BMP file from raw BGR pixel data.
+ * @param filename Output file path.
+ * @param pixels Pixel data in BGR order, bottom-up (OpenGL convention).
+ * @param width Image width in pixels.
+ * @param height Image height in pixels.
+ * @return True if the file was written successfully.
+ */
+bool WriteBMP(const std::string& filename, const uint8_t* pixels, uint32_t width, uint32_t height);
+
+/**
+ * @brief Reads the currently bound GL_READ_FRAMEBUFFER and writes a BMP.
+ * @param filename Output file path.
+ * @param width Framebuffer width.
+ * @param height Framebuffer height.
+ * @return True if the file was written successfully.
+ */
+bool CaptureFramebufferBMP(const std::string& filename, uint32_t width, uint32_t height);
+
+/**
+ * @brief Generates an auto-filename: <prefix>-YYYY-MM-DD-HHMMSS.bmp
+ */
+std::string AutoScreenshotFilename(const std::string& prefix);
