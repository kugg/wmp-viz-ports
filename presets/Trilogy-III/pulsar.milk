wave_0_per_point1=x = sample;
wave_0_per_point2=y = 0.5 - value1 * 0.4;
wave_0_per_point3=g = 0.5 + 0.5 * sin(sample * 3.14159);
wave_0_per_point4=b = 0.5 + 0.5 * sin(sample * 6.2832);
wave_0_per_point5=r = g * 0.1;
wave_0_per_point6=a = 0.9;

wavecode_1_enabled=1
wavecode_1_bSpectrum=1
