wave_1_per_point1=x = sample;
wave_1_per_point2=y = 0.5 + value1 * 0.4;
wave_1_per_point3=g = 0.5 + 0.5 * sin(sample * 3.14159);
wave_1_per_point4=b = 0.5 + 0.5 * sin(sample * 6.2832);
wave_1_per_point5=r = g * 0.1;
wave_1_per_point6=a = 0.7;

comp_1=`shader_body
comp_2=`{
comp_3=`  ret = tex2D(sampler_main, uv).rgb;
comp_4=`}
